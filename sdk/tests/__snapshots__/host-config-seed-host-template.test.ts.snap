    "hostStyle": "claude",
    "mcpProfile": {
      "apps": {
        "sandbox": {
          "allowFeatures": {
            "fullscreen": "*",
          },
          "csp": {
            "cspDirectives": {
              "base-uri": [
                "'self'",
              ],
              "connect-src": [
                "'self'",
                "https://esm.sh",
              ],
              "font-src": [
                "'self'",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
              "form-action": [
                "'self'",
              ],
              "frame-src": [
                "'self'",
              ],
              "img-src": [
                "'self'",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
              "media-src": [
                "'self'",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
              "script-src": [
                "'self'",
                "'unsafe-eval'",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
              "style-src": [
                "'self'",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
              "worker-src": [
                "'self'",
                "blob:",
                "https://esm.sh",
                "https://assets.claude.ai",
              ],
            },
            "mode": "declared",
          },
          "permissions": {
            "allow": {
              "clipboardWrite": true,
            },
            "mode": "custom",
          },
          "sandboxAttrs": [
            "allow-forms",
          ],
        },
        "uiInitialize": {
          "hostInfo": {
            "name": "Claude",
            "version": "1.0.0",
          },
        },
      },
      "initialize": {
        "clientInfo": {
          "name": "claude-ai",
          "version": "0.1.0",
        },
      },
      "profileVersion": 1,
    },
