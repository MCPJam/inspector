{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "icons": {
    "library": "lucide"
  },
  "name": "MCPJam Inspector",
  "colors": {
    "primary": "#EF5B25",
    "light": "#FF8B5C",
    "dark": "#C94818"
  },
  "background": {
    "color": {
      "light": "#FAF9F5",
      "dark": "#2D2A23"
    }
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "fonts": {
    "heading": { "family": "Geist", "weight": 500 },
    "body": { "family": "Geist", "weight": 400 }
  },
  "styling": {
    "codeblocks": {
      "theme": "css-variables"
    }
  },
  "favicon": "/mcp_jam.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Get Started",
        "pages": [
          "index",
          "getting-started",
          "installation",
          "hosted/overview",
          "troubleshooting/common-errors",
          "troubleshooting/error-codes",
          "changelog/overview"
        ]
      },
      {
        "tab": "Inspector",
        "groups": [
          {
            "group": "Connect",
            "icon": "plug",
            "pages": [
              "inspector/home",
              "inspector/clients",
              "inspector/projects",
              "inspector/protocol-versions"
            ]
          },
          {
            "group": "MCP Apps",
            "icon": "layout-dashboard",
            "pages": [
              "inspector/playground",
              "inspector/views",
              "inspector/evals",
              "inspector/host-templates"
            ]
          },
          {
            "group": "Auth & Conformance",
            "icon": "shield-check",
            "pages": [
              "inspector/guided-oauth",
              "inspector/xaa-debugger",
              "inspector/xaa-test-idp"
            ]
          },
          {
            "group": "Primitives",
            "icon": "puzzle",
            "pages": [
              "inspector/tools-prompts-resources",
              "inspector/skills"
            ]
          },
          {
            "group": "Embedding",
            "icon": "code",
            "pages": ["inspector/launch-from-code"]
          },
          {
            "group": "Recipes",
            "icon": "map",
            "pages": ["guides/first-mcp-app", "guides/first-chatgpt-app-react"]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Guides",
            "icon": "map",
            "pages": [
              "cli/overview",
              "cli/server-inspection",
              "cli/oauth-conformance",
              "cli/oauth-login",
              "cli/apps-conformance",
              "cli/tools-resources-prompts",
              "cli/ci",
              "cli/telemetry"
            ]
          },
          {
            "group": "Reference",
            "icon": "book",
            "pages": ["cli/reference"]
          }
        ]
      },
      {
        "tab": "SDK",
        "tag": "v1",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": ["sdk/index", "sdk/quickstart"]
          },
          {
            "group": "Concepts",
            "icon": "map",
            "pages": [
              "sdk/concepts/connecting-servers",
              "sdk/concepts/testing-with-llms",
              "sdk/concepts/running-evals",
              "sdk/concepts/saving-results",
              "sdk/concepts/multi-provider"
            ]
          },
          {
            "group": "Reference",
            "icon": "book",
            "pages": [
              "sdk/reference/mcp-client-manager",
              "sdk/reference/host-runner",
              "sdk/reference/prompt-result",
              "sdk/reference/eval-test",
              "sdk/reference/eval-suite",
              "sdk/reference/eval-reporting",
              "sdk/reference/validators",
              "sdk/reference/llm-providers",
              "sdk/reference/protocol-conformance",
              "sdk/reference/oauth-conformance",
              "sdk/reference/apps-conformance",
              "sdk/reference/widget-runtime"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "tag": "Preview",
        "groups": [
          {
            "group": "API Guides",
            "icon": "map",
            "pages": ["reference/public-api", "reference/api-keys"]
          },
          {
            "group": "Endpoints",
            "icon": "braces",
            "openapi": "reference/openapi.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/JEnDtz8X6z",
          "icon": "discord"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/MCPJam/inspector",
          "icon": "github"
        },
        {
          "anchor": "Website",
          "href": "https://mcpjam.com",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/mcp_jam_light.png",
    "dark": "/logo/mcp_jam_dark.png"
  },
  "redirects": [
    { "source": "/inspector/workspaces", "destination": "/inspector/projects" },
    { "source": "/inspector/chat", "destination": "/inspector/playground" },
    { "source": "/inspector/app-builder", "destination": "/inspector/playground" },
    { "source": "/inspector/test-cases", "destination": "/inspector/evals" },
    { "source": "/sdk/reference/test-agent", "destination": "/sdk/reference/host-runner" }
  ],
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/MCPJam/inspector"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/JEnDtz8X6z",
      "github": "https://github.com/MCPJam/inspector",
      "website": "https://mcpjam.com",
      "linkedin": "https://www.linkedin.com/company/109011364/",
      "x": "https://x.com/mcpjams"
    }
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Lost in the inspector?",
      "description": "Try the [getting started guide](/getting-started), the [CLI overview](/cli/overview), or the [SDK reference](/sdk/index). Related pages are listed below."
    }
  }
}
