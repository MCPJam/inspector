{
  "name": "@mcpjam/mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "MCPJam remote MCP server (Cloudflare Worker)",
  "scripts": {
    "build:ui": "vite build --config vite.config.ts",
    "bundle:ui:html": "node scripts/bundle-mcp-app-html.mjs",
    "ui:watch": "vite build --config vite.config.ts --watch --mode development",
    "dev": "npm run build:ui && wrangler dev --env staging",
    "start": "npm run build:ui && wrangler dev --env staging",
    "deploy:staging": "npm run build:ui && wrangler deploy --env staging",
    "deploy": "npm run build:ui && wrangler deploy",
    "typecheck": "npm run build -w @mcpjam/sdk && npm run build:ui && tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@mcpjam/design-system": "*",
    "@mcpjam/sdk": "*",
    "@modelcontextprotocol/ext-apps": "0.4.0",
    "@modelcontextprotocol/sdk": "1.26.0",
    "agents": "^0.5.0",
    "convex": "^1.26.2",
    "jose": "^6.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.26.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vite-plugin-singlefile": "^2.3.0",
    "wrangler": "^4.67.0"
  }
}
