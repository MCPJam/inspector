# WorkOS auth. Reuse values from the staging Railway service where possible.
# WORKOS_COOKIE_PASSWORD must be at least 32 characters.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3100/callback

# Employee-only gate. Matches the contract enforced in
# mcpjam-inspector/server/config.ts.
MCPJAM_NONPROD_LOCKDOWN=true
MCPJAM_EMPLOYEE_EMAIL_DOMAINS=mcpjam.com

# Read-only data sources for the dashboard tiles.
RAILWAY_API_TOKEN=
CONVEX_DEPLOY_KEY_STAGING=
CONVEX_DEPLOY_KEY_PROD=
GITHUB_PAT=

# Write-scoped PAT used by the release dispatch route to trigger
# release.yml and deploy-mcp-prod.yml via workflow_dispatch.
# Fine-grained, Actions: Read and write on MCPJam/inspector.
GITHUB_DISPATCH_PAT=
